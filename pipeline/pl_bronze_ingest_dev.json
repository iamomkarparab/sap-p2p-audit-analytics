										],
										"policy": {
											"timeout": "0.00:10:00",
											"retry": 2,
											"retryIntervalInSeconds": 30,
											"secureOutput": false,
											"secureInput": false
										},
										"userProperties": [],
										"typeProperties": {
											"storedProcedureName": "dbo.usp_update_watermark",
											"storedProcedureParameters": {
												"table_name": {
													"value": {
														"value": "@item().folder_path",
														"type": "Expression"
													},
													"type": "String"
												}
											}
										},
										"linkedServiceName": {
											"referenceName": "ls_sqldb_watermark_dev",
											"type": "LinkedServiceReference"
										}
