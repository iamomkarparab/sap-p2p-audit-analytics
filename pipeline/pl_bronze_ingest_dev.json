										},
										"userProperties": [],
										"typeProperties": {
											"source": {
												"type": "AzureSqlSource",
												"sqlReaderStoredProcedureName": "dbo.usp_get_watermark",
												"storedProcedureParameters": {
													"table_name": {
														"type": "String",
														"value": {
															"value": "@item().folder_path",
															"type": "Expression"
														}
													}
												},
												"queryTimeout": "02:00:00",
												"partitionOption": "None"
											},
											"dataset": {
												"referenceName": "ds_sqldb_dev",
												"type": "DatasetReference"
											},
											"firstRowOnly": true
										}
