												"files_copied": {
													"value": "0",
													"type": "Int32"
												},
												"files_skipped": {
													"value": "0",
													"type": "Int32"
												},
												"files_failed": {
													"value": {
														"value": "@length(activity('Filter_CSV_Files').output.value)",
														"type": "Expression"
													},
													"type": "Int32"
												},
												"new_watermark": {
													"value": null,
													"type": "DateTime"
												}
											}
										},
										"linkedServiceName": {
											"referenceName": "ls_sqldb_watermark_dev",
											"type": "LinkedServiceReference"
										}
									},
									{
										"name": "Notify_Child_Failure",
										"type": "WebActivity",
										"dependsOn": [
											{
												"activity": "Log_Folder_Failed",
												"dependencyConditions": [
													"Succeeded",
													"Failed"
												]
											}
										],
										"policy": {
											"timeout": "0.00:10:00",
											"retry": 1,
											"retryIntervalInSeconds": 30,
											"secureOutput": false,
											"secureInput": false
										},
										"userProperties": [],
										"typeProperties": {
											"method": "POST",
											"url": "https://httpbin.org/post",
											"body": {
												"value": "@concat('{\"title\": \"ADF Pipeline Failure\", \"text\": \"Bronze pipeline failed for folder: ', item().folder_path, '. Pipeline: ', pipeline().Pipeline, '. RunId: ', pipeline().RunId, '. Time: ', utcNow(), '\"}')",
												"type": "Expression"
											}
										}
									}
								]
							}
						}
					]
				}
			},
			{
				"name": "Notify_Pipeline_Failure",
				"type": "WebActivity",
				"dependsOn": [
					{
						"activity": "ForEach_Folder",
						"dependencyConditions": [
							"Failed"
						]
					}
				],
				"policy": {
					"timeout": "0.00:10:00",
					"retry": 1,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"method": "POST",
					"url": "https://httpbin.org/post",
					"body": {
						"value": "@concat('{\"title\": \"ADF Pipeline Failure\", \"text\": \"Bronze ingestion pipeline failed. Pipeline: ', pipeline().Pipeline, '. RunId: ', pipeline().RunId, '. Time: ', utcNow(), '\"}')",
						"type": "Expression"
					}
				}
			}
		],
