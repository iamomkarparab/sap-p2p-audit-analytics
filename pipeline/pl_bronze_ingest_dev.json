								"ifTrueActivities": [
									{
										"name": "Execute_Child_Pipeline",
										"type": "ExecutePipeline",
										"dependsOn": [],
										"policy": {
											"secureInput": false
										},
										"userProperties": [],
										"typeProperties": {
											"pipeline": {
												"referenceName": "pl_bronze_copy_dev",
												"type": "PipelineReference"
											},
											"waitOnCompletion": true,
