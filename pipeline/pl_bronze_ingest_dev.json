										"policy": {
											"timeout": "0.00:10:00",
											"retry": 2,
											"retryIntervalInSeconds": 30,
											"secureOutput": false,
											"secureInput": false
										},
										"userProperties": [],
										"typeProperties": {
											"storedProcedureName": "dbo.usp_update_pipeline_run_audit",
											"storedProcedureParameters": {
												"run_id": {
													"value": {
														"value": "@pipeline().RunId",
														"type": "Expression"
													},
													"type": "String"
												},
												"folder_name": {
													"value": {
														"value": "@item().folder_path",
														"type": "Expression"
													},
													"type": "String"
												},
												"end_time": {
													"value": {
														"value": "@utcNow()",
														"type": "Expression"
													},
													"type": "DateTime"
												},
												"status": {
													"value": "Succeeded",
													"type": "String"
												},
												"files_copied": {
													"value": {
														"value": "@activity('Lookup_Run_Counts').output.firstRow.files_copied",
														"type": "Expression"
													},
													"type": "Int32"
