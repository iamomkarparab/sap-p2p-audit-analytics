												"p_folder_name": {
													"value": "@item().folder_path",
													"type": "Expression"
												},
												"p_child_items": {
													"value": "@activity('Filter_CSV_Files').output.value",
													"type": "Expression"
												},
												"p_last_modified": {
													"value": "@activity('Lookup_Watermark').output.firstRow.last_modified",
													"type": "Expression"
												},
												"p_expected_column_count": {
													"value": "@item().expected_column_count",
													"type": "Expression"
												},
												"p_pipeline_run_id": {
													"value": "@pipeline().RunId",
													"type": "Expression"
												}
											}
										}
									},
