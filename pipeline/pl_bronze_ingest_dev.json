									},
									{
										"name": "Log_Folder_Failed",
										"type": "SqlServerStoredProcedure",
										"dependsOn": [
											{
												"activity": "Execute_Child_Pipeline",
												"dependencyConditions": [
													"Failed"
												]
											}
										],
										"policy": {
											"timeout": "0.00:10:00",
											"retry": 2,
											"retryIntervalInSeconds": 30,
											"secureOutput": false,
											"secureInput": false
										},
										"userProperties": [],
										"typeProperties": {
											"storedProcedureName": "dbo.usp_update_pipeline_run_audit",
											"storedProcedureParameters": {
												"run_id": {
													"value": {
														"value": "@pipeline().RunId",
														"type": "Expression"
													},
													"type": "String"
