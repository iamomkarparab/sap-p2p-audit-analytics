{
    "$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "factoryName": {
            "type": "string",
            "metadata": "Data Factory name",
            "defaultValue": "adf-onprem-adls-ingestion-dev"
        },
        "ls_adls_bronze_dev_accountKey": {
            "type": "secureString",
            "metadata": "Secure string for 'accountKey' of 'ls_adls_bronze_dev'"
        },
        "ls_databricks_dev_accessToken": {
            "type": "secureString",
            "metadata": "Secure string for 'accessToken' of 'ls_databricks_dev'"
        },
        "ls_filesystem_src_dev_password": {
            "type": "secureString",
            "metadata": "Secure string for 'password' of 'ls_filesystem_src_dev'"
        },
        "ls_sqldb_watermark_dev_password": {
            "type": "secureString",
            "metadata": "Secure string for 'password' of 'ls_sqldb_watermark_dev'"
        },
        "ls_adls_bronze_dev_properties_typeProperties_url": {
            "type": "string",
            "defaultValue": "https://stsapadlsrawdev.dfs.core.windows.net/"
        },
        "ls_databricks_dev_properties_typeProperties_existingClusterId": {
            "type": "string",
            "defaultValue": "0402-021600-d2fdmzyz"
        },
        "ls_filesystem_src_dev_properties_typeProperties_host": {
            "type": "string",
            "defaultValue": "C:\\Users\\Omkar Parab\\Desktop\\Azure Project\\files"
        },
        "ls_filesystem_src_dev_properties_typeProperties_userId": {
            "type": "string",
            "defaultValue": ".\\omkar parab"
        },
        "ls_sqldb_watermark_dev_properties_typeProperties_server": {
            "type": "string",
            "defaultValue": "sql-p2p-src-dev-01.database.windows.net"
        },
        "ls_sqldb_watermark_dev_properties_typeProperties_database": {
            "type": "string",
            "defaultValue": "sqldb-p2p-free-dev"
        },
        "ls_sqldb_watermark_dev_properties_typeProperties_userName": {
            "type": "string",
            "defaultValue": "sqladmin_p2p"
        },
        "containerUri": {
            "type": "string",
            "metadata": "URI to storage account containing linked ARM templates"
        },
        "containerSasToken": {
            "type": "string",
            "metadata": "Sas token to storage account containing linked ARM templates"
        }
    },
    "variables": {
        "factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
    },
    "resources": [
        {
            "name": "adf-onprem-adls-ingestion-dev_ArmTemplate_0",
            "type": "Microsoft.Resources/deployments",
            "apiVersion": "2024-03-01",
            "properties": {
                "mode": "incremental",
                "templateLink": {
                    "uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
                    "contentVersion": "1.0.0.0"
                },
                "parameters": {
                    "factoryName": {
                        "value": "[parameters('factoryName')]"
                    },
                    "ls_adls_bronze_dev_accountKey": {
                        "value": "[parameters('ls_adls_bronze_dev_accountKey')]"
                    },
                    "ls_databricks_dev_accessToken": {
                        "value": "[parameters('ls_databricks_dev_accessToken')]"
                    },
                    "ls_sqldb_watermark_dev_password": {
                        "value": "[parameters('ls_sqldb_watermark_dev_password')]"
                    },
                    "ls_filesystem_src_dev_password": {
                        "value": "[parameters('ls_filesystem_src_dev_password')]"
                    },
                    "ls_adls_bronze_dev_properties_typeProperties_url": {
                        "value": "[parameters('ls_adls_bronze_dev_properties_typeProperties_url')]"
                    },
                    "ls_databricks_dev_properties_typeProperties_existingClusterId": {
                        "value": "[parameters('ls_databricks_dev_properties_typeProperties_existingClusterId')]"
                    },
                    "ls_sqldb_watermark_dev_properties_typeProperties_server": {
                        "value": "[parameters('ls_sqldb_watermark_dev_properties_typeProperties_server')]"
                    },
                    "ls_sqldb_watermark_dev_properties_typeProperties_database": {
                        "value": "[parameters('ls_sqldb_watermark_dev_properties_typeProperties_database')]"
                    },
                    "ls_sqldb_watermark_dev_properties_typeProperties_userName": {
                        "value": "[parameters('ls_sqldb_watermark_dev_properties_typeProperties_userName')]"
                    },
                    "ls_filesystem_src_dev_properties_typeProperties_host": {
                        "value": "[parameters('ls_filesystem_src_dev_properties_typeProperties_host')]"
                    },
                    "ls_filesystem_src_dev_properties_typeProperties_userId": {
                        "value": "[parameters('ls_filesystem_src_dev_properties_typeProperties_userId')]"
                    }
                }
            },
            "dependsOn": []
        }
    ]
